<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:ex="http://example.org/ontology#">

    <owl:Ontology rdf:about="http://example.org/ontology"/>

    <owl:Class rdf:about="http://example.org/ontology#연구자"/>
    <owl:Class rdf:about="http://example.org/ontology#주제"/>
    <owl:Class rdf:about="http://example.org/ontology#과제"/>
    <owl:Class rdf:about="http://example.org/ontology#기술"/>

    <owl:ObjectProperty rdf:about="http://example.org/ontology#연구주제">
        <rdfs:domain rdf:resource="http://example.org/ontology#연구자"/>
        <rdfs:range rdf:resource="http://example.org/ontology#주제"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology#연구과제">
        <rdfs:domain rdf:resource="http://example.org/ontology#연구자"/>
        <rdfs:range rdf:resource="http://example.org/ontology#과제"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology#보유기술">
        <rdfs:domain rdf:resource="http://example.org/ontology#연구자"/>
        <rdfs:range rdf:resource="http://example.org/ontology#기술"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology#필요기술">
        <rdfs:range rdf:resource="http://example.org/ontology#기술"/>
    </owl:ObjectProperty>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#이현민">
        <rdf:type rdf:resource="http://example.org/ontology#연구자"/>
        <ex:연구주제 rdf:resource="http://example.org/ontology#생성형_AI"/>
        <ex:연구주제 rdf:resource="http://example.org/ontology#컴퓨터비전"/>
        <ex:연구과제 rdf:resource="http://example.org/ontology#영상_AI기반_배전전력구_지중케이블_아크탐지_솔루션_개발"/>
        <ex:연구과제 rdf:resource="http://example.org/ontology#AI활용_반부패_청렴_및_계약_업무_적정성_안내_챗봇_개발"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#Python"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#PyTorch"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#LLM"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#자연어처리"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#Pretraining"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#Supervised_Fine-Tuning"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#Reinforcement_Learning"/>
        <ex:보유기술 rdf:resource="http://example.org/ontology#생성형_AI"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#생성형_AI">
        <rdf:type rdf:resource="http://example.org/ontology#주제"/>
        <rdf:type rdf:resource="http://example.org/ontology#기술"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#Python"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#PyTorch"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#LLM"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#자연어처리"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#대규모_분산_처리"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#데이터_실시간_처리"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#구조도_설계"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#컴퓨터비전">
        <rdf:type rdf:resource="http://example.org/ontology#주제"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#Python"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#DeepLearning"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#Video_Processing"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#영상_AI기반_배전전력구_지중케이블_아크탐지_솔루션_개발">
        <rdf:type rdf:resource="http://example.org/ontology#과제"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#Python"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#DeepLearning"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#AI활용_반부패_청렴_및_계약_업무_적정성_안내_챗봇_개발">
        <rdf:type rdf:resource="http://example.org/ontology#과제"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#Python"/>
        <ex:필요기술 rdf:resource="http://example.org/ontology#DeepLearning"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Python"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#PyTorch"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#LLM"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#자연어처리"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#Pretraining"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#Supervised_Fine-Tuning"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#Reinforcement_Learning"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#대규모_분산_처리"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#데이터_실시간_처리"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#구조도_설계"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#DeepLearning"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/ontology#Video_Processing"><rdf:type rdf:resource="http://example.org/ontology#기술"/></owl:NamedIndividual>

</rdf:RDF>
