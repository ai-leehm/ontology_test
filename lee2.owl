<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/genai-ontology#"
     xml:base="http://example.org/genai-ontology"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <owl:Ontology rdf:about="http://example.org/genai-ontology">
        <rdfs:comment>이현민 연구원 및 연구주제/과제 기술 스택 온톨로지</rdfs:comment>
    </owl:Ontology>

    <owl:ObjectProperty rdf:about="#hasResearchTopic">
        <rdfs:label xml:lang="ko">연구주제</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasResearchProject">
        <rdfs:label xml:lang="ko">연구과제</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasSkill">
        <rdfs:label xml:lang="ko">보유기술</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#requiresSkill">
        <rdfs:label xml:lang="ko">필요기술</rdfs:label>
    </owl:ObjectProperty>

    <owl:Class rdf:about="#Node_Python"><rdfs:label xml:lang="ko">Python</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_PyTorch"><rdfs:label xml:lang="ko">PyTorch</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_LLM"><rdfs:label xml:lang="ko">LLM</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_NLP"><rdfs:label xml:lang="ko">자연어처리</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_Pretraining"><rdfs:label xml:lang="ko">Pretraining</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_SFT"><rdfs:label xml:lang="ko">Supervised Fine-Tuning</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_RL"><rdfs:label xml:lang="ko">Reinforcement Learning</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_DistProc"><rdfs:label xml:lang="ko">대규모 분산 처리</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_RealTimeProc"><rdfs:label xml:lang="ko">데이터 실시간 처리</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_ArchDesign"><rdfs:label xml:lang="ko">구조도 설계</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_DeepLearning"><rdfs:label xml:lang="ko">DeepLearning</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Node_VideoProc"><rdfs:label xml:lang="ko">Video Processing</rdfs:label></owl:Class>

    <owl:Class rdf:about="#Node_GenAI">
        <rdfs:label xml:lang="ko">생성형 AI</rdfs:label>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_Python"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_PyTorch"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_LLM"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_NLP"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_DistProc"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_RealTimeProc"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_ArchDesign"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Node_ComputerVision">
        <rdfs:label xml:lang="ko">컴퓨터 비전</rdfs:label>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_Python"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_DeepLearning"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_VideoProc"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Node_Proj_ArcDetect">
        <rdfs:label xml:lang="ko">영상 AI기반 배전전력구 지중케이블 아크탐지 솔루션 개발</rdfs:label>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_Python"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_DeepLearning"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Node_Proj_Chatbot">
        <rdfs:label xml:lang="ko">AI활용 반부패 청렴 및 계약 업무 적정성 안내 챗봇 개발</rdfs:label>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_Python"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#requiresSkill"/><owl:someValuesFrom rdf:resource="#Node_DeepLearning"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="#Node_LeeHyunMin">
        <rdfs:label xml:lang="ko">이현민</rdfs:label>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasResearchTopic"/><owl:someValuesFrom rdf:resource="#Node_GenAI"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasResearchTopic"/><owl:someValuesFrom rdf:resource="#Node_ComputerVision"/></owl:Restriction></rdfs:subClassOf>
        
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasResearchProject"/><owl:someValuesFrom rdf:resource="#Node_Proj_ArcDetect"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasResearchProject"/><owl:someValuesFrom rdf:resource="#Node_Proj_Chatbot"/></owl:Restriction></rdfs:subClassOf>
        
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_Python"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_PyTorch"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_LLM"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_NLP"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_Pretraining"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_SFT"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_RL"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#Node_GenAI"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

</rdf:RDF>