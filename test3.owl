        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#performs"/><owl:someValuesFrom rdf:resource="#O_Task_HR_Social"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#O_Skill_NLP_LLM"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#O_Skill_CloudBigData"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkill"/><owl:someValuesFrom rdf:resource="#O_Skill_Platform"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkillLevel"/><owl:someValuesFrom rdf:resource="#O_Domain_Power"/></owl:Restriction></rdfs:subClassOf>
        <rdfs:subClassOf><owl:Restriction><owl:onProperty rdf:resource="#hasSkillLevel"/><owl:someValuesFrom rdf:resource="#O_Domain_AI_Modelling"/></owl:Restriction></rdfs:subClassOf>
    </owl:Class>

